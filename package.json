    "imports": {
        "#test-runtime": {
            "bun": "./test/lib/testRuntime.bun.ts",
            "default": "./test/lib/testRuntime.vitest.ts"
        }
    },
    "keywords": [
        "jooq",
        "querydsl",
        "typescript",
        "mariadb",
        "mysql",
        "oracle",
        "sqlite",
        "sqlserver",
        "sql-server",
        "sql server",
        "postgre sql",
        "postgresql",
        "typesql",
        "type-sql",
        "type sql",
        "type-safe sql",
        "type safe sql",
        "typesafe sql",
        "sql",
        "query builder",
        "query",
        "orm",
        "linq"
    ],
    "scripts": {
        "generate-prisma": "prisma generate --schema src/examples/prisma/postgresql.prisma; prisma generate --schema src/examples/prisma/mysql.prisma; prisma generate --schema src/examples/prisma/mariadb.prisma; prisma generate --schema src/examples/prisma/sqlite.prisma; prisma generate --schema src/examples/prisma/sqlserver.prisma",
        "all-examples": "sh ./scripts/all-examples.sh",
        "no-docker-examples": "sh ./scripts/no-docker-examples.sh",
        "coverage": "npm_config_user_agent=npm/coverage nyc sh ./scripts/all-examples.sh",
        "validate": "tsc --noEmit",
        "validate:tsgo": "tsgo --noEmit",
        "validate:tests": "tsgo -p test/tsconfig.json --noEmit",
        "validate:tests:tsc": "tsc -p test/tsconfig.tsc.json --noEmit",
        "tests": "bash scripts/tests.sh",
        "tests:audit": "bash scripts/tests-audit.sh",
        "tests:stop-containers": "bash scripts/tests-stop-containers.sh",
        "tests:reopen": "bash scripts/tests-reopen.sh",
        "test:fast": "bash scripts/tests.sh",
        "test:no-docker": "bash scripts/tests.sh --wasm",
        "test:complete:fast": "bash scripts/tests.sh --docker",
        "test:complete:fast:newest": "bash scripts/tests.sh --docker --docker-scope newest",
        "test:complete": "bash scripts/tests.sh --docker --wasm",
        "coverage:fast": "bash scripts/tests.sh --use-vitest --report --coverage --open",
        "coverage:no-docker": "bash scripts/tests.sh --use-vitest --report --wasm --coverage --mode sequential --open",
        "coverage:complete:fast": "bash scripts/tests.sh --use-vitest --report --docker --coverage --open",
        "coverage:complete:fast:newest": "bash scripts/tests.sh --use-vitest --report --docker --docker-scope newest --coverage --open",
        "coverage:complete": "bash scripts/tests.sh --use-vitest --report --docker --wasm --coverage --mode sequential --open",
        "coverage:for-discover-tests": "bash scripts/tests.sh --use-vitest --coverage --coverage-format json --coverage-format json-summary --coverage-format text-summary --scope newest",
        "coverage:reopen": "bash scripts/tests-reopen.sh",
        "build": "rm -rf dist/*; tsc --version && tsc -p tsconfig.build.json",
        "build:tsgo": "rm -rf dist/*; tsgo --version && tsgo -p tsconfig.build.json",
        "dist": "npm run build && cp LICENSE.md package.json README.md dist && cd dist && npm publish",
        "dist-alpha": "npm run build && cp LICENSE.md package.json README.md dist && cd dist && npm publish --tag alpha",
        "dist-beta": "npm run build && cp LICENSE.md package.json README.md dist && cd dist && npm publish --tag beta",
        "test-dist": "npm run build && cp LICENSE.md package.json README.md dist && cd dist && npm publish --dry-run",
        "docs": "mkdocs serve",
        "create-single-doc-file": "sh ./scripts/create-single-doc-file.sh"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/juanluispaz/ts-sql-query.git"
    },
    "bugs": {
        "url": "https://github.com/juanluispaz/ts-sql-query/issues"
    },
    "homepage": "https://ts-sql-query.readthedocs.io/",
    "devDependencies": {
        "@electric-sql/pglite": "^0.4.4",
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/adapter-mariadb": "^7.8.0",
        "@prisma/adapter-mssql": "^7.8.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
        "@testcontainers/postgresql": "^11.10.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/bun": "^1.3.13",
        "@types/istanbul-lib-coverage": "^2.0.6",
        "@types/istanbul-lib-report": "^3.0.3",
        "@types/istanbul-reports": "^3.0.4",
        "@types/lcov-parse": "^1.0.2",
        "@types/mssql": "^12.3.0",
        "@types/oracledb": "^6.10.3",
        "@types/pg": "^8.20.0",
        "@types/sqlite3": "^3.1.11",
        "@typescript/native-preview": "^7.0.0-dev.20260516.1",
        "@vitest/coverage-v8": "^4.0.0",
        "@vitest/ui": "^4.1.6",
        "better-sqlite3": "^12.9.0",
        "lcov-parse": "^1.0.0",
        "mariadb": "^3.5.2",
        "monocart-coverage-reports": "^2.12.11",
        "mssql": "^12.5.0",
        "mysql2": "^3.22.2",
        "nyc": "^18.0.0",
        "oracledb": "^6.10.0",
        "pg": "^8.20.0",
        "postgres": "^3.4.9",
        "prisma": "^7.8.0",
        "sqlite3": "^6.0.1",
        "synchronous-promise": "^2.0.17",
        "testcontainers": "^11.10.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "uuid": "^14.0.0",
        "vitest": "^4.0.0",
        "vitest-monocart-coverage": "^4.0.2"
    },
    "nyc": {
        "exclude": [
            "src/examples/**"
        ],
        "reporter": [
            "html"
        ],
        "include": [
            "src/**"
        ]
    },
    "engines": {
        "node": ">=22"
    }
